{
    "name": "flexpik/filament-studio",
    "description": "Dynamic data model manager for Filament — build unlimited collections with custom fields, EAV storage, versioning, and multi-tenancy",
    "keywords": ["laravel", "filament", "eav", "crud", "dynamic-models", "data-manager"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Flexpik",
            "email": "info@flexpick.net",
            "homepage": "https://flexpick.net",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/flexpik/filament-studio",
    "support": {
        "issues": "https://github.com/flexpik/filament-studio/issues",
        "source": "https://github.com/flexpik/filament-studio"
    },
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "dedoc/scramble": "^0.13",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-mutate": "^4.0",
        "spatie/laravel-permission": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "Flexpik\\FilamentStudio\\": "src/",
            "Flexpik\\FilamentStudio\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Flexpik\\FilamentStudio\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Flexpik\\FilamentStudio\\FilamentStudioServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
